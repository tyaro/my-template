# Normalize line endings to LF in the repo, checked out per-OS default
# unless overridden below. See docs/improvements.md §5.2.
* text=auto eol=lf

# Binary assets: never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.dll binary
*.lib binary
*.exe binary
*.pdb binary
*.sqlite3 binary
*.db binary
